# =============================================================================
# Ubumwe Beauty — Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
#
# Convention:
#   - All variables are prefixed with the service they belong to.
#   - Required for production = marked with [REQUIRED]
#   - Optional / dev-only = marked with [OPTIONAL]
#   - Secrets marked with [SECRET] — never commit real values.
# =============================================================================


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | production | test
APP_NAME="Ubumwe Beauty"
APP_URL=http://localhost:3000           # Public-facing URL (used in emails, OG tags)


# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL) — [REQUIRED] in production
# -----------------------------------------------------------------------------
# Local dev: SQLite (already configured). Production: swap to PostgreSQL.
#
# PostgreSQL connection string format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Example (Supabase / Railway / Neon):
#   DATABASE_URL=postgresql://postgres:password@db.abc.supabase.co:5432/ubumwe?schema=public
#
DATABASE_URL="file:./db/custom.db"      # ← current dev (SQLite)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ubumwe  # ← production


# -----------------------------------------------------------------------------
# NEXTAUTH (Authentication) — [REQUIRED] if enabling user accounts
# -----------------------------------------------------------------------------
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# PAYMENTS — MTN MoMo (PayPack) — [REQUIRED] for real MoMo payments
# -----------------------------------------------------------------------------
# Sign up at https://paypack.co.rw/ to get API credentials.
PAYPACK_CLIENT_ID=your-paypack-client-id
PAYPACK_CLIENT_SECRET=your-paypack-client-secret [SECRET]
PAYPACK_ENVIRONMENT=production           # production | sandbox
# Webhook URL PayPack will call on payment events:
PAYPACK_WEBHOOK_URL=https://your-domain.com/api/webhooks/paypack


# -----------------------------------------------------------------------------
# PAYMENTS — Flutterwave (Cards + Mobile Money fallback) — [OPTIONAL]
# -----------------------------------------------------------------------------
# Sign up at https://flutterwave.com/ to get API keys.
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxx-X [SECRET]
FLW_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxx [SECRET]
FLW_WEBHOOK_HASH=your-webhook-hash [SECRET]
FLW_WEBHOOK_URL=https://your-domain.com/api/webhooks/flutterwave


# -----------------------------------------------------------------------------
# SMS — Africa's Talking — [REQUIRED] for order SMS notifications
# -----------------------------------------------------------------------------
# Sign up at https://africastalking.com/ to get API key.
AT_USERNAME=ubumwe_beauty
AT_API_KEY=your-africas-talking-api-key [SECRET]
AT_SENDER_ID=UBUMWE                      # 11-char max alphanumeric sender ID
# Alternative SMS provider:
PINDO_API_KEY=your-pindo-api-key [SECRET] # https://pindo.io/


# -----------------------------------------------------------------------------
# STORAGE — Cloudinary (product images) — [REQUIRED] for image uploads
# -----------------------------------------------------------------------------
# Sign up at https://cloudinary.com/ to get credentials.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret [SECRET]
# Upload preset for unsigned uploads from the admin dashboard:
CLOUDINARY_UPLOAD_PRESET=ubumwe_uploads


# -----------------------------------------------------------------------------
# SEARCH — Algolia (product search) — [OPTIONAL]
# -----------------------------------------------------------------------------
# Sign up at https://www.algolia.com/ to get credentials.
ALGOLIA_APP_ID=your-app-id
ALGOLIA_ADMIN_API_KEY=your-admin-api-key [SECRET]
ALGOLIA_SEARCH_API_KEY=your-search-api-key
ALGOLIA_INDEX_NAME=ubumwe_products


# -----------------------------------------------------------------------------
# CACHE — Redis (session, cart, rate limiting) — [OPTIONAL] for MVP
# -----------------------------------------------------------------------------
# Use Upstash Redis for serverless: https://upstash.com/
REDIS_URL=redis://default:password@localhost:6379
# Or use Upstash REST API for edge-compatible cache:
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token [SECRET]


# -----------------------------------------------------------------------------
# EMAIL — Resend (transactional emails) — [OPTIONAL] for MVP
# -----------------------------------------------------------------------------
# Sign up at https://resend.com/ to get API key.
RESEND_API_KEY=re_xxxxxxxxxxxx [SECRET]
EMAIL_FROM="Ubumwe Beauty <hello@ubumwe.beauty>"
EMAIL_REPLY_TO=hello@ubumwe.beauty


# -----------------------------------------------------------------------------
# ADMIN — Dashboard access control
# -----------------------------------------------------------------------------
# Comma-separated list of admin email addresses (for simple allow-list auth).
# In production, replace with proper NextAuth + Admin role.
ADMIN_EMAILS=admin@ubumwe.beauty,owner@ubumwe.beauty
# Simple shared secret for the admin route (replace with real auth later):
ADMIN_ACCESS_KEY=change-this-to-a-long-random-string [SECRET]


# -----------------------------------------------------------------------------
# RATE LIMITING & SECURITY
# -----------------------------------------------------------------------------
# Max API requests per minute per IP (default: 60)
RATE_LIMIT_PER_MINUTE=60
# CORS allowed origins (comma-separated):
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://ubumwe.beauty


# -----------------------------------------------------------------------------
# ANALYTICS — [OPTIONAL]
# -----------------------------------------------------------------------------
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
# Plausible Analytics domain (alternative to GA):
PLAUSIBLE_DOMAIN=ubumwe.beauty


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Toggle features on/off without code changes
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REAL_PAYMENTS=false               # false = simulate payment flow
ENABLE_SEARCH_INDEXING=false             # sync products to Algolia
ENABLE_REDIS_CACHE=false
