# FreedomCosmeticShop environment template
# Copy to .env.local for local development. Never commit real secret values.

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FreedomCosmeticShop
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=RWF
NEXT_PUBLIC_COUNTRY=Rwanda
NEXT_PUBLIC_WHATSAPP=
APP_NAME=FreedomCosmeticShop
APP_URL=http://localhost:3000

# Store
STORE_NAME=FreedomCosmeticShop
STORE_CURRENCY=RWF
STORE_TIMEZONE=Africa/Kigali

# Supabase PostgreSQL — approved production project: hsdqahltrqjeaskhheis
# Transaction pool URL used by serverless runtime. Prisma requires pgbouncer=true.
DATABASE_URL="postgresql://postgres.hsdqahltrqjeaskhheis:REPLACE_WITH_PASSWORD@REPLACE_WITH_POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Session/direct pool URL used only for schema management.
DIRECT_URL="postgresql://postgres.hsdqahltrqjeaskhheis:REPLACE_WITH_PASSWORD@REPLACE_WITH_POOLER_HOST:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=https://hsdqahltrqjeaskhheis.supabase.co
SUPABASE_PROJECT_REF=hsdqahltrqjeaskhheis

# Custom JWT authentication (the NEXTAUTH_* name is retained for backwards-compatible secret resolution; NextAuth is not used)
NEXTAUTH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
JWT_REFRESH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Cloudinary
CLOUDINARY_CLOUD_NAME=dohoc0tmp
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dohoc0tmp
CLOUDINARY_API_KEY=REPLACE_WITH_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_CLOUDINARY_API_SECRET
CLOUDINARY_UPLOAD_PRESET=freedom_uploads

# PayPack / Mobile Money
PAYPACK_CLIENT_ID=
PAYPACK_CLIENT_SECRET=
PAYPACK_WEBHOOK_SECRET=
PAYPACK_ENVIRONMENT=sandbox
PAYPACK_WEBHOOK_URL=http://localhost:3000/api/webhooks/paypack

# Flutterwave cards
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_HASH=
FLW_WEBHOOK_URL=http://localhost:3000/api/webhooks/flutterwave

# SMS providers
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=FREEDOM
PINDO_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Optional search/cache services
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_SEARCH_API_KEY=
ALGOLIA_INDEX_NAME=freedom_products
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin and cron
ADMIN_EMAILS=
ADMIN_ACCESS_KEY=
CRON_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Feature flags — production payment and communication features fail closed while disabled
ALLOW_SEED=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REAL_PAYMENTS=false
ENABLE_SEARCH_INDEXING=false
ENABLE_REDIS_CACHE=false
