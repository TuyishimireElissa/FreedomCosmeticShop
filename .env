# =============================================================================
# Ubumwe Beauty — Local Development Environment
# =============================================================================
# This file contains development-only defaults.
# For production, see .env.example and set all required variables.
# =============================================================================

# Database (SQLite for dev)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=dev-only-secret-change-in-production-32chars
NEXTAUTH_URL=http://localhost:3000

# Feature flags (all disabled for dev — no real SMS/payments)
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REAL_PAYMENTS=false
ENABLE_SEARCH_INDEXING=false
ENABLE_REDIS_CACHE=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Admin
ADMIN_EMAILS=admin@ubumwe.beauty
