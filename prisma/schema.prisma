// =============================================================================
// Ubumwe Beauty — Complete Prisma Schema (SQLite / Development)
// =============================================================================
//
// 19 models for a production-ready Rwanda cosmetics e-commerce platform:
//   1.  User           — with +250 phone, role enum, soft delete
//   2.  StaffProfile   — extends User for admin/staff (model #19)
//   3.  Category       — hierarchical (parent/child self-relation)
//   4.  Brand          — product brands
//   5.  Product        — with skinType, shade, ingredients
//   6.  Cart           — authenticated user cart
//   7.  CartItem       — cart line items
//   8.  Order          — RWF currency, sequential order number
//   9.  OrderItem      — snapshot line items
//  10.  Payment        — MTN MoMo / Airtel / Card / COD
//  11.  Delivery       — driver + tracking
//  12.  Review         — with photos, skin type, shade used
//  13.  Wishlist       — user ↔ product
//  14.  Address        — Rwanda province/district/sector/cell/village
//  15.  Coupon         — percentage / fixed / free shipping
//  16.  LoyaltyPoints  — points ledger (earn / redeem / expire)
//  17.  BlogPost       — content marketing
//  18.  Banner         — promotional banners
//  19.  Notification   — in-app / SMS / email / push
//
// SQLite limitations (vs PostgreSQL):
//   - Enums stored as String (valid values documented in comments)
//   - Arrays stored as JSON string (use JSON.parse/stringify in app code)
//   - No @db.Text (use String)
//   - No full-text search (use contains)
//
// For the PostgreSQL production version, see prisma/schema.postgres.prisma
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. USER
// =============================================================================
// Rwanda phone format: +250 7XX XXX XXX (stored as "+2507XXXXXXXX" or "07XXXXXXXX")
// Validated in app code via regex: /^(?:\+250|0)?7[0-9]{8}$/

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String   @unique // Rwanda: +2507XXXXXXXX
  passwordHash String?

  // Role: CUSTOMER | ADMIN | STAFF | MANAGER
  role      String   @default("CUSTOMER")

  avatar    String?

  // Loyalty program
  loyaltyPoints Int  @default(0)

  // Email verification
  emailVerifiedAt DateTime?

  // Soft delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders              Order[]
  cart                Cart?
  reviews             Review[]
  wishlistItems       Wishlist[]
  addresses           Address[]
  notifications       Notification[]
  loyaltyTransactions LoyaltyPoints[]
  blogPosts           BlogPost[]
  staffProfile        StaffProfile?

  @@index([phone])
  @@index([email])
  @@index([role])
  @@index([isDeleted])
}

// =============================================================================
// 2. STAFF PROFILE (Admin/Staff — model #19)
// =============================================================================
// Extends User with staff-specific fields. 1:1 relation.
// Created when role = ADMIN, STAFF, or MANAGER.

model StaffProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Staff identification
  employeeId  String  @unique
  // Department: SALES | MARKETING | LOGISTICS | SUPPORT | FINANCE | MANAGEMENT
  department  String
  position    String

  hireDate    DateTime @default(now())
  isActive    Boolean  @default(true)

  // Permissions: JSON array like ["orders.read", "orders.update", "products.crud"]
  permissions String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@index([isActive])
}

// =============================================================================
// 3. CATEGORY (hierarchical — parent/child)
// =============================================================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  icon        String?

  // Hierarchical self-relation
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")

  // Display
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  // Soft delete
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

// =============================================================================
// 4. BRAND
// =============================================================================

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String?
  website     String?
  country     String?  // Country of origin
  isActive    Boolean  @default(true)

  // Soft delete
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@index([slug])
  @@index([isActive])
}

// =============================================================================
// 5. PRODUCT (with cosmetics-specific fields)
// =============================================================================
// Prices in RWF (Rwandan Franc) as Int to avoid float precision issues.
// images, skinType, shades, ingredients stored as JSON strings (SQLite).

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String
  shortDescription  String?  // For product cards (max ~150 chars)

  // Pricing (RWF)
  price             Int
  compareAt         Int?     // Original price for "on sale" display
  costPrice         Int?     // For margin calculation (admin only)

  // Inventory
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  sku               String?  @unique
  barcode           String?

  // Media — JSON array of image URLs: '["url1", "url2"]'
  images            String   @default("[]")
  videoUrl          String?

  // ─── Cosmetics-specific fields ───────────────────────────────────
  // skinType: JSON array of values from: ALL, OILY, DRY, COMBINATION, SENSITIVE, NORMAL
  // Example: '["OILY", "COMBINATION"]'
  skinType          String?  // JSON array
  // shades: JSON array of shade names for makeup products
  // Example: '["Deep", "Medium", "Light"]'
  shades            String?  // JSON array
  // ingredients: JSON array of ingredient names
  // Example: '["Vitamin C", "Hyaluronic Acid", "Glycerin"]'
  ingredients       String?  // JSON array
  // size: e.g., "50ml", "100g", "30 capsules"
  size              String?
  // usageInstructions: how to use the product
  usageInstructions String?
  // warnings: cautions and warnings
  warnings          String?
  // ─── End cosmetics-specific fields ───────────────────────────────

  // Ratings (denormalized for quick display)
  rating            Float    @default(0)
  reviewsCount      Int      @default(0)

  // Flags
  featured          Boolean  @default(false)
  isNew             Boolean  @default(false)
  isActive          Boolean  @default(true)

  // Soft delete
  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])

  brandId           String?
  brand             Brand?   @relation(fields: [brandId], references: [id])

  orderItems        OrderItem[]
  reviews           Review[]
  wishlistItems     Wishlist[]
  cartItems         CartItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([featured])
  @@index([isActive])
  @@index([isDeleted])
  @@index([price])
  @@index([createdAt])
}

// =============================================================================
// 6. CART (for authenticated users)
// =============================================================================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Cached totals (updated on every CartItem change)
  totalItems Int     @default(0)
  subtotal   Int     @default(0) // RWF

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     CartItem[]

  @@index([userId])
}

// =============================================================================
// 7. CART ITEM
// =============================================================================

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  quantity  Int
  // Price snapshot (in case product price changes after adding to cart)
  price     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent duplicate products in same cart — update quantity instead
  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// =============================================================================
// 8. ORDER (RWF currency)
// =============================================================================
// Order numbers: sequential, human-readable. Format: UB-YYYY-NNNNN
// e.g., UB-2026-00001

model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique

  // Customer snapshot (works for guest checkout)
  customerName  String
  customerPhone String   // Rwanda: +2507XXXXXXXX
  customerEmail String?

  // Optional link to authenticated user
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  // Delivery address (Rwanda structure)
  address       String
  city          String
  district      String?
  sector        String?
  province      String
  notes         String?

  // Totals in RWF
  subtotal      Int
  discountAmount Int     @default(0)
  deliveryFee   Int      @default(0)
  total         Int

  // Coupon applied
  couponId      String?
  coupon        Coupon?  @relation(fields: [couponId], references: [id])

  // Loyalty points earned from this order
  loyaltyPointsEarned Int @default(0)

  // Status: PENDING | CONFIRMED | PROCESSING | SHIPPED | DELIVERED | CANCELLED | RETURNED
  status        String   @default("PENDING")

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  items         OrderItem[]
  payments      Payment[]
  delivery      Delivery?
  reviews       Review[]

  @@index([orderNumber])
  @@index([status])
  @@index([customerPhone])
  @@index([userId])
  @@index([createdAt])
  @@index([couponId])
}

// =============================================================================
// 9. ORDER ITEM (snapshot at purchase time)
// =============================================================================

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  // Snapshot fields (preserved even if product is deleted)
  name      String
  price     Int      // RWF at time of purchase
  quantity  Int
  image     String?
  // Selected shade (for makeup products)
  shade     String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// =============================================================================
// 10. PAYMENT (MTN MoMo / Airtel / Card / COD)
// =============================================================================

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Method: MTN_MOMO | AIRTEL_MONEY | CARD | COD
  method    String

  // Provider transaction details
  providerTransactionId String? @unique // From PayPack / Flutterwave
  providerReference     String?

  // Amount in RWF
  amount    Int

  // Status: PENDING | PAID | FAILED | REFUNDED
  status    String   @default("PENDING")

  // Mobile money
  phoneNumber String? // Customer's MoMo phone number

  // Card (last 4 digits only — never store full card number)
  cardLast4  String?
  cardBrand  String?  // VISA | MASTERCARD | AMEX

  // Failure
  failureReason String?

  // Timestamps
  initiatedAt DateTime @default(now())
  completedAt DateTime?

  @@index([orderId])
  @@index([providerTransactionId])
  @@index([status])
  @@index([method])
}

// =============================================================================
// 11. DELIVERY (driver + tracking)
// =============================================================================

model Delivery {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Status: PENDING | ASSIGNED | PICKED_UP | IN_TRANSIT | DELIVERED | FAILED
  status    String   @default("PENDING")

  // Driver / courier
  driverName   String?
  driverPhone  String? // Rwanda: +2507XXXXXXXX
  vehiclePlate String?

  // Tracking
  trackingCode       String? @unique
  estimatedArrival   DateTime?
  actualArrival      DateTime?

  // Failure
  failureReason String?

  // Internal notes
  notes    String?

  // Timestamps
  assignedAt   DateTime?
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([driverPhone])
  @@index([trackingCode])
}

// =============================================================================
// 12. REVIEW (with photo upload)
// =============================================================================

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])

  // Review content
  rating    Int      // 1-5 stars
  title     String?
  body      String?

  // Photos — JSON array of image URLs
  photos    String?  // '["url1", "url2"]'

  // Cosmetics-specific context
  skinType    String? // Reviewer's skin type
  shadeUsed   String? // Which shade they used

  // Moderation
  isApproved Boolean  @default(false)
  isFeatured Boolean  @default(false)

  // Engagement
  helpfulVotes Int    @default(0)

  // Soft delete
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([orderId])
  @@index([isApproved])
  @@index([rating])
  @@index([createdAt])
}

// =============================================================================
// 13. WISHLIST
// =============================================================================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Prevent duplicate wishlist entries
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// =============================================================================
// 14. ADDRESS (Rwanda districts / sectors)
// =============================================================================
// Rwanda administrative structure:
//   Province (5) → District (30) → Sector → Cell → Village
// Reference data in src/lib/rwanda-locations.ts

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label           String  // "Home", "Work", etc.
  recipientName   String
  recipientPhone  String  // Rwanda: +2507XXXXXXXX

  // Rwanda administrative hierarchy
  province    String
  district    String  // e.g., "Nyarugenge", "Gasabo"
  sector      String  // e.g., "Nyarugenge", "Kimirombe"
  cell        String?
  village     String?
  streetAddress String? // Additional street-level detail

  // GPS coordinates (optional, for delivery optimization)
  latitude   Float?
  longitude  Float?

  isDefault  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([district])
  @@index([province])
}

// =============================================================================
// 15. COUPON / DISCOUNT
// =============================================================================

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?

  // Type: PERCENTAGE | FIXED | FREE_SHIPPING
  type        String
  // For PERCENTAGE: 0-100 (e.g., 10 = 10% off)
  // For FIXED: amount in RWF (e.g., 5000 = RWF 5,000 off)
  value       Int

  // Minimum order amount to qualify (RWF)
  minOrderAmount Int?
  // Maximum discount cap (for PERCENTAGE type, in RWF)
  maxDiscountAmount Int?

  // Usage limits
  usageLimit       Int?  // Total times usable (null = unlimited)
  usageLimitPerUser Int  @default(1)
  usedCount        Int   @default(0)

  // Validity window
  startsAt    DateTime
  endsAt      DateTime?

  // Applicability
  appliesToAllProducts Boolean @default(true)
  // JSON arrays of IDs when appliesToAllProducts = false
  categoryIds String?  // '["catId1", "catId2"]'
  productIds  String?  // '["prodId1", "prodId2"]'

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

// =============================================================================
// 16. LOYALTY POINTS (ledger)
// =============================================================================
// Each row is one transaction (earn / redeem / expire / bonus).
// User.loyaltyPoints is the current balance (denormalized for quick reads).

model LoyaltyPoints {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Transaction
  points    Int      // Positive = earned, Negative = redeemed
  // Type: EARNED | REDEEMED | EXPIRED | BONUS | ADJUSTMENT
  type      String
  reason    String   // e.g., "Order UB-2026-00001", "Signup bonus"

  // Related order (if earned from an order)
  orderId   String?

  // Balance after this transaction
  balanceAfter Int

  // Expiry (earned points may expire)
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
  @@index([expiresAt])
}

// =============================================================================
// 17. BLOG POST
// =============================================================================

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String   // Markdown or HTML

  coverImage String?

  // Author
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])

  // SEO
  metaTitle       String?
  metaDescription String?

  // Tags — JSON array: '["skincare", "rutine", "kigali"]'
  tags       String?

  // Status: DRAFT | PUBLISHED | ARCHIVED
  status     String   @default("DRAFT")
  publishedAt DateTime?

  // Metrics
  viewCount  Int      @default(0)

  // Soft delete
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
}

// =============================================================================
// 18. BANNER / PROMOTION
// =============================================================================

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String   // Desktop image URL
  mobileImage String? // Mobile-optimized image

  // CTA link
  // linkType: PRODUCT | CATEGORY | URL | BLOG_POST | NONE
  linkType  String?
  linkUrl   String?

  // Placement: HOME_HERO | HOME_PROMO | SIDEBAR | CATEGORY_TOP | CHECKOUT_BANNER
  placement String   @default("HOME_HERO")

  // Scheduling
  startsAt  DateTime?
  endsAt    DateTime?

  // Display
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placement])
  @@index([isActive])
  @@index([sortOrder])
}

// =============================================================================
// 19. NOTIFICATION
// =============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Type: ORDER_UPDATE | PROMOTION | REVIEW_REQUEST | SYSTEM | LOW_STOCK
  type      String
  title     String
  body      String

  // Additional context — JSON: '{"orderId": "abc123", "status": "SHIPPED"}'
  data      String?

  // Deep link
  // linkType: ORDER | PRODUCT | CATEGORY | URL | NONE
  linkType  String?
  linkUrl   String?

  // Status
  isRead    Boolean  @default(false)
  readAt    DateTime?

  // Channel: IN_APP | SMS | EMAIL | PUSH
  channel   String   @default("IN_APP")
  sentAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([channel])
  @@index([createdAt])
}
